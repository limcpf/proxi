{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-start.mjs\"",
            "statusMessage": "문서 라우터 체크리스트 불러오는 중"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/user-prompt-submit.mjs\"",
            "statusMessage": "문서 구조 작업 여부 확인 중"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/post-tool-use-docs.mjs\"",
            "statusMessage": "문서 변경 후속 검사 중"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/stop-verify-enforcer.mjs\"",
            "statusMessage": "마무리 전 검증 상태 확인 중",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
